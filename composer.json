{
  "name": "emotionwise/emotionwise-php",
  "description": "PHP wrapper for the emotionwise.ai API.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "EmotionWise"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Emotionwise\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Emotionwise\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  }
}
